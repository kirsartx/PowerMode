<Window x:Class="PowerModeWinUI.InsightsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PowerMode Insights">
    <Window.SystemBackdrop><MicaBackdrop Kind="BaseAlt"/></Window.SystemBackdrop>
    <Grid x:Name="Root" Padding="24" RowSpacing="14" UseLayoutRounding="True" Loaded="Root_Loaded">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock x:Name="HeaderText" Text="系统洞察" Style="{ThemeResource TitleTextBlockStyle}"/><TextBlock x:Name="SubheaderText" Text="功耗、温度、电池健康与切换历史" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"><Button x:Name="RefreshButton" Content="刷新" Click="RefreshButton_Click"/><Button x:Name="ExportCsvButton" Content="导出 CSV" Click="ExportCsvButton_Click"/></StackPanel></Grid>
        <Grid Grid.Row="1" ColumnSpacing="10"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource StatusCardStyle}"><StackPanel><TextBlock x:Name="CpuMetricLabel" Text="CPU 负载" Style="{StaticResource CardLabelStyle}"/><TextBlock x:Name="CpuMetricValue" Text="—" Style="{StaticResource CardValueStyle}"/></StackPanel></Border>
            <Border Grid.Column="1" Style="{StaticResource StatusCardStyle}"><StackPanel><TextBlock x:Name="GpuPowerLabel" Text="GPU 功耗" Style="{StaticResource CardLabelStyle}"/><TextBlock x:Name="GpuPowerValue" Text="—" Style="{StaticResource CardValueStyle}"/></StackPanel></Border>
            <Border Grid.Column="2" Style="{StaticResource StatusCardStyle}"><StackPanel><TextBlock x:Name="TemperatureLabel" Text="最高温度" Style="{StaticResource CardLabelStyle}"/><TextBlock x:Name="TemperatureValue" Text="—" Style="{StaticResource CardValueStyle}"/></StackPanel></Border>
            <Border Grid.Column="3" Style="{StaticResource StatusCardStyle}"><StackPanel><TextBlock x:Name="BatteryLabel" Text="电池" Style="{StaticResource CardLabelStyle}"/><TextBlock x:Name="BatteryValue" Text="—" Style="{StaticResource CardValueStyle}"/></StackPanel></Border>
            <Border Grid.Column="4" Style="{StaticResource StatusCardStyle}"><StackPanel><TextBlock x:Name="HealthLabel" Text="电池健康" Style="{StaticResource CardLabelStyle}"/><TextBlock x:Name="HealthValue" Text="—" Style="{StaticResource CardValueStyle}"/></StackPanel></Border>
        </Grid>
        <TabView Grid.Row="2" IsAddTabButtonVisible="False">
            <TabViewItem x:Name="TrendTab" Header="趋势" IsClosable="False">
                <Grid Padding="12" RowSpacing="10">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock x:Name="TrendHint" Text="最近采样的 GPU 功耗与温度" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="14">
                            <StackPanel Orientation="Horizontal" Spacing="6"><Ellipse Width="9" Height="9" Fill="{ThemeResource AccentFillColorDefaultBrush}"/><TextBlock x:Name="PowerLegend" Text="GPU 功耗"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6"><Ellipse Width="9" Height="9" Fill="#FFF59E0B"/><TextBlock x:Name="TemperatureLegend" Text="温度"/></StackPanel>
                        </StackPanel>
                    </Grid>
                    <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="10" Padding="12">
                        <Grid>
                            <Canvas x:Name="TrendCanvas" MinHeight="240" SizeChanged="TrendCanvas_SizeChanged">
                                <Polyline x:Name="PowerLine" Stroke="{ThemeResource AccentFillColorDefaultBrush}" StrokeThickness="2" StrokeLineJoin="Round"/>
                                <Polyline x:Name="TemperatureLine" Stroke="#FFF59E0B" StrokeThickness="2" StrokeLineJoin="Round"/>
                            </Canvas>
                            <TextBlock x:Name="TrendEmptyText" Text="暂无采样数据" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabViewItem>
            <TabViewItem x:Name="HistoryTab" Header="切换历史" IsClosable="False"><ListView x:Name="HistoryList" Padding="8"/></TabViewItem>
            <TabViewItem x:Name="BatteryTab" Header="电池健康" IsClosable="False"><ScrollViewer><StackPanel Padding="16" Spacing="10"><TextBlock x:Name="BatteryDetails" TextWrapping="Wrap"/><Button x:Name="BatteryReportButton" Content="生成 Windows 电池报告" HorizontalAlignment="Left" Click="BatteryReportButton_Click"/></StackPanel></ScrollViewer></TabViewItem>
        </TabView>
        <Grid Grid.Row="3"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><InfoBar x:Name="StatusInfo" IsOpen="False" IsClosable="False"/><Button x:Name="DiagnosticButton" Grid.Column="1" Content="导出诊断包" Click="DiagnosticButton_Click"/></Grid>
    </Grid>
</Window>
