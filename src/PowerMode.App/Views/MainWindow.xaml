<Window
    x:Class="PowerModeWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PowerMode">
    <Window.SystemBackdrop><MicaBackdrop Kind="Base"/></Window.SystemBackdrop>
    <Grid x:Name="RootGrid" Padding="28,22" RowSpacing="18" UseLayoutRounding="True" SizeChanged="RootGrid_SizeChanged" KeyDown="RootGrid_KeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Border Width="38" Height="38" CornerRadius="10" Background="{ThemeResource AccentFillColorSecondaryBrush}">
                    <FontIcon Glyph="&#xE945;" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel>
                    <TextBlock Text="PowerMode" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock x:Name="SubtitleText" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="·" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        <TextBlock x:Name="LastUpdatedText" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <ToggleButton x:Name="ExperienceModeButton"
                              Click="ExperienceModeButton_Click"
                              AutomationProperties.Name="切换简单或专业模式">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE713;"/>
                        <TextBlock x:Name="ExperienceModeText"/>
                    </StackPanel>
                </ToggleButton>
                <StackPanel x:Name="ProfessionalQuickActions" Orientation="Horizontal" Spacing="8">
                    <ToggleButton x:Name="AutoQuickToggle" Click="AutoQuickToggle_Click"><StackPanel Orientation="Horizontal" Spacing="6"><FontIcon Glyph="&#xE945;"/><TextBlock x:Name="AutoQuickText"/></StackPanel></ToggleButton>
                    <ToggleButton x:Name="LiveQuickToggle" Click="LiveQuickToggle_Click"><StackPanel Orientation="Horizontal" Spacing="6"><FontIcon Glyph="&#xE9D9;"/><TextBlock x:Name="LiveQuickText"/></StackPanel></ToggleButton>
                    <Button x:Name="RefreshButton" AutomationProperties.AcceleratorKey="F5" Click="RefreshButton_Click"><StackPanel Orientation="Horizontal" Spacing="6"><FontIcon x:Name="RefreshIcon" Glyph="&#xE72C;"/><ProgressRing x:Name="RefreshProgressRing" Width="16" Height="16" IsActive="False" Visibility="Collapsed"/><TextBlock x:Name="RefreshButtonText"/></StackPanel></Button>
                    <Button x:Name="FeaturesButton" Click="FeaturesButton_Click"><StackPanel Orientation="Horizontal" Spacing="6"><FontIcon Glyph="&#xE713;"/><TextBlock x:Name="FeaturesButtonText"/></StackPanel></Button>
                    <Button x:Name="InsightsButton" Click="InsightsButton_Click"><StackPanel Orientation="Horizontal" Spacing="6"><FontIcon Glyph="&#xE9D2;"/><TextBlock x:Name="InsightsButtonText"/></StackPanel></Button>
                </StackPanel>
                <Button x:Name="LanguageButton" Click="LanguageButton_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="10" RowSpacing="10">
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource StatusCardStyle}"><Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition/></Grid.ColumnDefinitions><FontIcon Glyph="&#xE8D7;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/><StackPanel Grid.Column="1"><TextBlock x:Name="ModeTitle" Style="{StaticResource CardLabelStyle}"/><TextBlock x:Name="ModeValue" Text="—" Style="{StaticResource CardValueStyle}"/></StackPanel></Grid></Border>
            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource StatusCardStyle}"><Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition/></Grid.ColumnDefinitions><FontIcon Glyph="&#xE7F8;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/><StackPanel Grid.Column="1"><TextBlock x:Name="GpuTitle" Style="{StaticResource CardLabelStyle}"/><TextBlock x:Name="GpuValue" Text="—" Style="{StaticResource CardValueStyle}"/></StackPanel></Grid></Border>
            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource StatusCardStyle}"><Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition/></Grid.ColumnDefinitions><FontIcon Glyph="&#xE83E;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/><StackPanel Grid.Column="1"><TextBlock x:Name="PowerTitle" Style="{StaticResource CardLabelStyle}"/><TextBlock x:Name="PowerValue" Text="—" Style="{StaticResource CardValueStyle}"/></StackPanel></Grid></Border>
            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource StatusCardStyle}"><Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition/></Grid.ColumnDefinitions><FontIcon Glyph="&#xE950;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/><StackPanel Grid.Column="1"><TextBlock x:Name="CpuTitle" Style="{StaticResource CardLabelStyle}"/><TextBlock x:Name="CpuValue" Text="—" Style="{StaticResource CardValueStyle}"/></StackPanel></Grid></Border>
            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource StatusCardStyle}"><Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition/></Grid.ColumnDefinitions><FontIcon Glyph="&#xE706;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/><StackPanel Grid.Column="1"><TextBlock x:Name="BrightnessTitle" Style="{StaticResource CardLabelStyle}"/><TextBlock x:Name="BrightnessValue" Text="—" Style="{StaticResource CardValueStyle}"/></StackPanel></Grid></Border>
            <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource StatusCardStyle}"><Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition/></Grid.ColumnDefinitions><FontIcon Glyph="&#xE708;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/><StackPanel Grid.Column="1"><TextBlock x:Name="SleepTitle" Style="{StaticResource CardLabelStyle}"/><TextBlock x:Name="SleepValue" Text="—" Style="{StaticResource CardValueStyle}"/></StackPanel></Grid></Border>
        </Grid>

        <Grid x:Name="MainContentGrid" Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions><ColumnDefinition Width="390"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Style="{StaticResource PanelStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="ModesTitle" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                        <TextBlock x:Name="ModesHintText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                        <Grid ColumnSpacing="8" RowSpacing="8">
                            <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <Button x:Name="RemoteButton" AutomationProperties.AcceleratorKey="1" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Stretch" MinHeight="64" Click="RemoteButton_Click"><Grid ColumnSpacing="10"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><FontIcon Glyph="&#xE8AF;"/><StackPanel Grid.Column="1"><TextBlock x:Name="RemoteButtonText" FontWeight="SemiBold"/><TextBlock x:Name="RemoteDescription" FontSize="12" Opacity="0.72"/></StackPanel><TextBlock Grid.Column="2" Text="1" Opacity="0.55" FontSize="12" VerticalAlignment="Center"/></Grid></Button>
                            <Button x:Name="SaverButton" AutomationProperties.AcceleratorKey="2" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch" MinHeight="64" Click="SaverButton_Click"><Grid ColumnSpacing="10"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><FontIcon Glyph="&#xE8BE;"/><StackPanel Grid.Column="1"><TextBlock x:Name="SaverButtonText" FontWeight="SemiBold"/><TextBlock x:Name="SaverDescription" FontSize="12" Opacity="0.72"/></StackPanel><TextBlock Grid.Column="2" Text="2" Opacity="0.55" FontSize="12" VerticalAlignment="Center"/></Grid></Button>
                            <Button x:Name="BalancedButton" AutomationProperties.AcceleratorKey="3" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Stretch" MinHeight="64" Click="BalancedButton_Click"><Grid ColumnSpacing="10"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><FontIcon Glyph="&#xE9E9;"/><StackPanel Grid.Column="1"><TextBlock x:Name="BalancedButtonText" FontWeight="SemiBold"/><TextBlock x:Name="BalancedDescription" FontSize="12" Opacity="0.72"/></StackPanel><TextBlock Grid.Column="2" Text="3" Opacity="0.55" FontSize="12" VerticalAlignment="Center"/></Grid></Button>
                            <Button x:Name="HighButton" AutomationProperties.AcceleratorKey="4" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" MinHeight="64" Click="HighButton_Click"><Grid ColumnSpacing="10"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><FontIcon Glyph="&#xE945;"/><StackPanel Grid.Column="1"><TextBlock x:Name="HighButtonText" FontWeight="SemiBold"/><TextBlock x:Name="HighDescription" FontSize="12" Opacity="0.72"/></StackPanel><TextBlock Grid.Column="2" Text="4" Opacity="0.55" FontSize="12" VerticalAlignment="Center"/></Grid></Button>
                        </Grid>
                        <StackPanel x:Name="ProfessionalModeControls" Spacing="10">
                            <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,6"/>
                            <TextBlock x:Name="CustomCpuTitle" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock x:Name="CpuHintText" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="72"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <Slider x:Name="CpuSlider" Minimum="20" Maximum="50" Value="28" StepFrequency="1" ValueChanged="CpuSlider_ValueChanged"/>
                                <NumberBox x:Name="CpuBox" Grid.Column="1" Minimum="20" Maximum="50" Value="28" SpinButtonPlacementMode="Compact" ValueChanged="CpuBox_ValueChanged"/>
                                <TextBlock Grid.Column="2" Text="%" VerticalAlignment="Center"/>
                            </Grid>
                            <Button x:Name="RemoteCustomButton" HorizontalAlignment="Stretch" Click="RemoteCustomButton_Click"/>
                            <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,6"/>
                            <TextBlock x:Name="AdvancedTitle" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Button x:Name="VerifyButton" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Stretch" Click="VerifyButton_Click"/>
                                <Button x:Name="RepairButton" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch" Click="RepairButton_Click"/>
                                <Button x:Name="WifiOnButton" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Stretch" Click="WifiOnButton_Click"/>
                                <Button x:Name="RemoteNoWifiButton" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Click="RemoteNoWifiButton_Click"/>
                            </Grid>
                            <TextBlock x:Name="CliPathText" Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border x:Name="ProfessionalLogPanel" Grid.Column="1" Style="{StaticResource PanelStyle}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="LogTitle" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock x:Name="LogHintText" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="·" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                <TextBlock x:Name="LogStatsText" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <ToggleButton x:Name="AutoScrollToggle" IsChecked="True" Padding="10,6"><StackPanel Orientation="Horizontal" Spacing="5"><FontIcon Glyph="&#xE74A;" FontSize="12"/><TextBlock x:Name="AutoScrollText"/></StackPanel></ToggleButton>
                            <Button x:Name="CopyLogButton" Padding="10,6" IsEnabled="False" Click="CopyLogButton_Click"><StackPanel Orientation="Horizontal" Spacing="5"><FontIcon Glyph="&#xE8C8;" FontSize="12"/><TextBlock x:Name="CopyLogText"/></StackPanel></Button>
                            <Button x:Name="ClearLogButton" Padding="10,6" IsEnabled="False" Click="ClearLogButton_Click"><StackPanel Orientation="Horizontal" Spacing="5"><FontIcon Glyph="&#xE74D;" FontSize="12"/><TextBlock x:Name="ClearLogText"/></StackPanel></Button>
                        </StackPanel>
                    </Grid>
                    <TextBox x:Name="LogBox" Grid.Row="1" IsReadOnly="True" IsSpellCheckEnabled="False" AcceptsReturn="True" TextWrapping="NoWrap" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14,12" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                </Grid>
            </Border>
        </Grid>

        <InfoBar x:Name="StatusBar" Grid.Row="3" IsOpen="True" IsClosable="False" Severity="Informational">
            <InfoBar.Content>
                <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="130"/></Grid.ColumnDefinitions><TextBlock x:Name="StatusText" VerticalAlignment="Center" AutomationProperties.LiveSetting="Polite"/><ProgressBar x:Name="BusyProgress" Grid.Column="1" IsIndeterminate="True" Visibility="Collapsed" VerticalAlignment="Center"/>
                </Grid>
            </InfoBar.Content>
        </InfoBar>
    </Grid>
</Window>
