<Window x:Class="PowerModeWinUI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PowerMode Feature Center">
    <Window.SystemBackdrop><MicaBackdrop Kind="BaseAlt"/></Window.SystemBackdrop>
    <Grid x:Name="Root" Padding="24" RowSpacing="16" UseLayoutRounding="True">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel><TextBlock x:Name="HeaderText" Text="功能中心" Style="{ThemeResource TitleTextBlockStyle}"/><TextBlock x:Name="SubheaderText" Text="自定义预设、自动切换和安全行为" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/></StackPanel>
        <TabView Grid.Row="1" IsAddTabButtonVisible="False" CanDragTabs="False">
            <TabViewItem x:Name="ProfilesTab" Header="自定义预设" IsClosable="False">
                <ScrollViewer><Grid Padding="16" ColumnSpacing="20">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="SavedProfileLabel" Text="已保存预设" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        <ComboBox x:Name="ProfileCombo" HorizontalAlignment="Stretch" SelectionChanged="ProfileCombo_SelectionChanged"/>
                        <TextBlock x:Name="ProfileNameLabel" Text="预设名称" Margin="0,8,0,0"/><TextBox x:Name="ProfileNameBox"/>
                        <TextBlock><Run x:Name="CpuMaxLabel" Text="CPU 上限"/><Run Text="  "/><Run x:Name="CpuMaxValue"/></TextBlock>
                        <Slider x:Name="CpuMaxSlider" Minimum="20" Maximum="100" Value="50" StepFrequency="1" ValueChanged="ProfileSlider_ValueChanged"/>
                        <StackPanel x:Name="BrightnessSettingsPanel" Spacing="8">
                            <TextBlock><Run x:Name="BrightnessLabel" Text="亮度"/><Run Text="  "/><Run x:Name="BrightnessValue"/></TextBlock>
                            <Slider x:Name="BrightnessSlider" Minimum="10" Maximum="100" Value="50" StepFrequency="5" ValueChanged="ProfileSlider_ValueChanged"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock x:Name="CpuMinLabel" Text="CPU 最低状态（%）"/><NumberBox x:Name="CpuMinBox" Minimum="0" Maximum="100" Value="5" SpinButtonPlacementMode="Compact"/>
                        <TextBlock x:Name="DisplayOffLabel" Text="自动关屏（秒，0 为永不）" Margin="0,8,0,0"/><NumberBox x:Name="DisplayOffBox" Minimum="0" Maximum="86400" Value="60" SpinButtonPlacementMode="Compact"/>
                        <CheckBox x:Name="DisableBoostCheck" Content="关闭 CPU 睿频" IsChecked="True" Margin="0,10"/>
                        <Expander x:Name="BatteryValuesExpander" Header="电池供电独立参数">
                            <StackPanel Spacing="8" Padding="0,8,0,0">
                                <ToggleSwitch x:Name="SeparateBatteryToggle" Header="启用独立 DC 参数" Toggled="SeparateBatteryToggle_Toggled"/>
                                <Grid x:Name="BatteryValuesPanel" ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock x:Name="BatteryCpuLabel" Text="CPU 上限"/><NumberBox x:Name="BatteryCpuBox" Minimum="5" Maximum="100" Value="35"/></StackPanel>
                                    <StackPanel Grid.Column="1"><TextBlock x:Name="BatteryBrightnessLabel" Text="亮度"/><NumberBox x:Name="BatteryBrightnessBox" Minimum="0" Maximum="100" Value="45"/></StackPanel>
                                    <StackPanel Grid.Column="2"><TextBlock x:Name="BatteryDisplayLabel" Text="关屏秒数"/><NumberBox x:Name="BatteryDisplayBox" Minimum="0" Maximum="86400" Value="120"/></StackPanel>
                                </Grid>
                            </StackPanel>
                        </Expander>
                        <TextBlock x:Name="ProfileHintText" Text="自定义预设基于节能方案，并保持睡眠与休眠关闭。" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                        <Grid ColumnSpacing="8" Margin="0,12,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><Button x:Name="SaveProfileButton" Content="保存预设" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Click="SaveProfileButton_Click"/><Button x:Name="DeleteProfileButton" Grid.Column="1" Content="删除" HorizontalAlignment="Stretch" Click="DeleteProfileButton_Click"/></Grid>
                        <Button x:Name="ApplyProfileButton" Content="立即应用此预设" HorizontalAlignment="Stretch" Click="ApplyProfileButton_Click"/>
                    </StackPanel>
                </Grid></ScrollViewer>
            </TabViewItem>
            <TabViewItem x:Name="AutomationTab" Header="自动化与安全" IsClosable="False">
                <ScrollViewer><StackPanel Padding="16" Spacing="10">
                    <ToggleSwitch x:Name="AutoSwitchToggle" Header="自动模式切换" OffContent="关闭" OnContent="开启"/>
                    <TextBlock x:Name="AutoHintText" Text="远程程序优先使用远程模式；高负载程序使用高性能；电池使用低功耗；其余使用平衡。" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                    <ToggleSwitch x:Name="RealtimeToggle" Header="实时状态监控" OffContent="关闭" OnContent="开启"/>
                    <ToggleSwitch x:Name="RestoreExitToggle" Header="退出时恢复启动前的电源方案" OffContent="关闭" OnContent="开启"/>
                    <ToggleSwitch x:Name="TemperatureProtectionToggle" Header="温度保护" OffContent="关闭" OnContent="开启"/>
                    <Grid ColumnSpacing="10"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock x:Name="TemperatureLimitLabel" Text="限制温度（°C）"/><NumberBox x:Name="TemperatureLimitBox" Minimum="50" Maximum="110" Value="90"/></StackPanel><StackPanel Grid.Column="1"><TextBlock x:Name="TemperatureRecoveryLabel" Text="恢复温度（°C）"/><NumberBox x:Name="TemperatureRecoveryBox" Minimum="40" Maximum="100" Value="75"/></StackPanel><StackPanel Grid.Column="2"><TextBlock x:Name="LowBatteryLabel" Text="低电量阈值（%）"/><NumberBox x:Name="LowBatteryBox" Minimum="5" Maximum="95" Value="30"/></StackPanel></Grid>
                    <TextBlock x:Name="IntervalLabel" Text="监控间隔（秒，最低 10）" Margin="0,8,0,0"/><NumberBox x:Name="IntervalBox" Minimum="10" Maximum="3600" Value="15" Width="160" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="RemoteProcessesLabel" Text="远程程序进程名（逗号分隔）"/><TextBox x:Name="RemoteProcessesBox"/>
                    <TextBlock x:Name="PerformanceProcessesLabel" Text="高性能程序进程名（逗号分隔）"/><TextBox x:Name="PerformanceProcessesBox"/>
                    <InfoBar x:Name="HotkeyHint" IsOpen="True" IsClosable="False" Severity="Informational" Message="全局快捷键：Ctrl + Alt + 1/2/3/4"/>
                    <StackPanel Orientation="Horizontal" Spacing="8"><Button x:Name="ImportButton" Content="导入配置" Click="ImportButton_Click"/><Button x:Name="ExportButton" Content="导出配置" Click="ExportButton_Click"/></StackPanel>
                </StackPanel></ScrollViewer>
            </TabViewItem>
            <TabViewItem x:Name="RulesTab" Header="规则" IsClosable="False">
                <Grid Padding="16" ColumnSpacing="16"><Grid.ColumnDefinitions><ColumnDefinition Width="280"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel Spacing="8"><TextBlock x:Name="RuleEditorTitle" Text="新建自动规则" Style="{ThemeResource SubtitleTextBlockStyle}"/><TextBox x:Name="RuleNameBox" Header="名称" PlaceholderText="例如：低电量节能"/><ComboBox x:Name="RuleConditionCombo" Header="条件" HorizontalAlignment="Stretch" SelectionChanged="RuleConditionCombo_SelectionChanged"/><TextBox x:Name="RuleValueBox" Header="条件值" PlaceholderText="进程名、百分比或时间"/><ComboBox x:Name="RuleModeCombo" Header="目标模式" HorizontalAlignment="Stretch"/><Button x:Name="AddRuleButton" Content="添加规则" Style="{StaticResource AccentButtonStyle}" Click="AddRuleButton_Click"/><TextBlock x:Name="RuleHelpText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/></StackPanel>
                    <Grid Grid.Column="1" RowSpacing="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock x:Name="RulesListTitle" Text="规则优先级（从上到下）" Style="{ThemeResource SubtitleTextBlockStyle}"/><ListView x:Name="RulesList" Grid.Row="1" SelectionMode="Single"/><StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"><Button x:Name="ToggleRuleButton" Content="启用/停用" Click="ToggleRuleButton_Click"/><Button x:Name="DeleteRuleButton" Content="删除" Click="DeleteRuleButton_Click"/></StackPanel></Grid>
                </Grid>
            </TabViewItem>
            <TabViewItem x:Name="SystemTab" Header="系统与维护" IsClosable="False">
                <ScrollViewer><StackPanel Padding="16" Spacing="10"><ToggleSwitch x:Name="NotificationsToggle" Header="显示模式切换通知"/><ToggleSwitch x:Name="PreviewManualSwitchesToggle" Header="手动切换前预览并确认"/><ToggleSwitch x:Name="StartWithWindowsToggle" Header="登录 Windows 时启动"/><ToggleSwitch x:Name="StartMinimizedToggle" Header="随 Windows 启动时隐藏到托盘"/><ToggleSwitch x:Name="ApplyLastModeToggle" Header="启动后应用上次模式"/><ToggleSwitch x:Name="HistoryToggle" Header="记录模式切换历史"/><ToggleSwitch x:Name="UpdateCheckToggle" Header="启动时检查更新"/><TextBox x:Name="UpdateUrlBox" Header="GitHub Releases API 地址" PlaceholderText="https://api.github.com/repos/owner/repo/releases/latest"/><NumberBox x:Name="BackupCountBox" Header="保留配置备份数量" Minimum="1" Maximum="50" Value="10" Width="180" HorizontalAlignment="Left"/><InfoBar x:Name="VendorInfo" IsOpen="True" IsClosable="False" Severity="Informational"/><StackPanel Orientation="Horizontal" Spacing="8"><Button x:Name="BackupButton" Content="立即备份配置" Click="BackupButton_Click"/><Button x:Name="RestoreBackupButton" Content="恢复最近备份" Click="RestoreBackupButton_Click"/><Button x:Name="CheckUpdateButton" Content="检查更新" Click="CheckUpdateButton_Click"/></StackPanel></StackPanel></ScrollViewer>
            </TabViewItem>
        </TabView>
        <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><InfoBar x:Name="SaveStatus" IsOpen="False" IsClosable="False" Severity="Success"/><Button x:Name="CloseButton" Grid.Column="1" Content="保存并关闭" Style="{StaticResource AccentButtonStyle}" Click="CloseButton_Click"/></Grid>
    </Grid>
</Window>
