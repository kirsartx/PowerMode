<Window x:Class="PowerModeWinUI.RecoveryCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PowerMode Recovery Center">
    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>
    <Grid x:Name="Root"
          Padding="24"
          RowSpacing="16"
          UseLayoutRounding="True"
          Loaded="Root_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock x:Name="HeaderText"
                       Text="恢复中心"
                       Style="{ThemeResource TitleTextBlockStyle}"/>
            <TextBlock x:Name="SubheaderText"
                       Text="撤销最近模式操作，或安全恢复 PowerMode 配置"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <Border Style="{StaticResource PanelStyle}">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE7A7;"
                                  FontSize="24"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                  VerticalAlignment="Top"/>
                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock x:Name="UndoTitle"
                                       Text="撤销最近模式切换"
                                       Style="{ThemeResource SubtitleTextBlockStyle}"/>
                            <TextBlock x:Name="UndoImpactText"
                                       Text="恢复到该操作之前的标准电源模式。"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="UndoAvailabilityText"
                                       Text="正在检查模式历史…"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button x:Name="UndoButton"
                                Grid.Column="2"
                                Content="撤销"
                                MinWidth="118"
                                IsEnabled="False"
                                VerticalAlignment="Center"
                                Click="UndoButton_Click"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource PanelStyle}">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE777;"
                                  FontSize="24"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                  VerticalAlignment="Top"/>
                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock x:Name="RestoreTitle"
                                       Text="恢复配置备份"
                                       Style="{ThemeResource SubtitleTextBlockStyle}"/>
                            <TextBlock x:Name="RestoreImpactText"
                                       Text="先备份当前设置，再原子恢复最近的不同配置；不会切换当前 Windows 电源方案。"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="RestoreAvailabilityText"
                                       Text="正在检查配置备份…"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button x:Name="RestoreButton"
                                Grid.Column="2"
                                Content="恢复配置"
                                MinWidth="118"
                                IsEnabled="False"
                                VerticalAlignment="Center"
                                Click="RestoreButton_Click"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource PanelStyle}">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE74D;"
                                  FontSize="24"
                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                  VerticalAlignment="Top"/>
                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock x:Name="ResetTitle"
                                       Text="重置为默认设置"
                                       Style="{ThemeResource SubtitleTextBlockStyle}"/>
                            <TextBlock x:Name="ResetImpactText"
                                       Text="创建安全备份后，仅重置 settings.json；历史、备份和遥测保持不变。"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="ResetAvailabilityText"
                                       Text="重置后使用简单体验和平衡模式偏好；不会切换当前 Windows 电源方案。"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button x:Name="ResetButton"
                                Grid.Column="2"
                                Content="重置默认值"
                                MinWidth="118"
                                IsEnabled="False"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                Click="ResetButton_Click"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <InfoBar x:Name="ResultInfoBar"
                 Grid.Row="2"
                 IsOpen="True"
                 IsClosable="False"
                 Severity="Informational">
            <InfoBar.Content>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ResultMessageText"
                               Text="正在检查可用的恢复操作。"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               AutomationProperties.LiveSetting="Polite"/>
                    <ProgressRing x:Name="BusyProgressRing"
                                  Grid.Column="1"
                                  Width="20"
                                  Height="20"
                                  IsActive="True"/>
                </Grid>
            </InfoBar.Content>
        </InfoBar>
    </Grid>
</Window>
