<Application
    x:Class="PowerModeWinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <FontFamily x:Key="ContentControlThemeFontFamily">Segoe UI Variable Text</FontFamily>
            <FontFamily x:Key="AppDisplayFontFamily">Segoe UI Variable Display</FontFamily>
            <Style x:Key="PanelStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="20"/>
            </Style>
            <Style x:Key="StatusCardStyle" TargetType="Border" BasedOn="{StaticResource PanelStyle}"><Setter Property="Padding" Value="14"/></Style>
            <Style x:Key="CardLabelStyle" TargetType="TextBlock"><Setter Property="FontFamily" Value="{StaticResource ContentControlThemeFontFamily}"/><Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/><Setter Property="FontSize" Value="12"/></Style>
            <Style x:Key="CardValueStyle" TargetType="TextBlock"><Setter Property="FontFamily" Value="{StaticResource AppDisplayFontFamily}"/><Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/><Setter Property="FontSize" Value="18"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="TextTrimming" Value="CharacterEllipsis"/><Setter Property="Margin" Value="0,5,0,0"/></Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
